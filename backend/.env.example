# Temple OS backend environment template
# Copy to backend/.env for local development or map these values from docker/.env in production.

# Runtime
NODE_ENV=development
PORT=3002
PUBLIC_SERVER_URL=http://127.0.0.1:3900
ALLOWED_ORIGIN=http://127.0.0.1:3900

# Database
DATABASE_URL=postgresql://postgres:change-this-password@localhost:5432/temple_os

# Auth
JWT_SECRET=change-this-to-a-long-random-secret

# Storage
UPLOAD_DIR=../storage/uploads
PLAQUE_TEMPLATE_ASSET_DIR=../storage/plaque-template-assets

# Central WeChat platform.
# Customer servers call this service. Do not expose WECHAT_PLATFORM_API_TOKEN to browsers.
WECHAT_PLATFORM_BASE_URL=http://127.0.0.1:3010
WECHAT_PLATFORM_API_TOKEN=change-this-shared-platform-api-token

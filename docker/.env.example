# Temple OS deployment environment template
# Copy this file to docker/.env on each customer server and change the values.

# Customer/site identity
APP_NAME=Temple OS
PUBLIC_SITE_URL=https://example.com
ALLOWED_ORIGIN=https://example.com
NEXT_PUBLIC_API_BASE=

# Database
POSTGRES_DB=temple_os
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgresql://postgres:change-this-password@localhost:5432/temple_os

# Backend security
JWT_SECRET=change-this-to-a-long-random-secret

# Runtime ports. Keep these internal behind Nginx unless there is a specific reason.
FRONTEND_PORT=3000
BACKEND_PORT=3002
PRINT_SERVICE_PORT=3001

# Storage paths. These should be backed up with the database.
UPLOAD_DIR=/opt/temple-os/storage/uploads
PLAQUE_TEMPLATE_ASSET_DIR=/opt/temple-os/storage/plaque-template-assets

# Optional payment / external integration placeholders
PAYMENT_PROVIDER=
PAYMENT_MERCHANT_ID=
PAYMENT_API_KEY=
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Central WeChat platform integration.
# Customer servers call the central platform; browsers and desktop clients must not see this token.
PUBLIC_SERVER_URL=https://example.com
WECHAT_PLATFORM_BASE_URL=https://wechat-platform.example.com
WECHAT_PLATFORM_API_TOKEN=change-this-shared-platform-api-token

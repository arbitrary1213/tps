version: '3.8'

services:
  temple-db:
    image: postgres:15-alpine
    container_name: temple-db
    environment:
      POSTGRES_DB: ${POSTGRES_DB:-temple_os}
      POSTGRES_USER: ${POSTGRES_USER:-postgres}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-postgres}
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./backup:/backup
    networks:
      - temple-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -d temple_os"]
      interval: 10s
      timeout: 5s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 512M
        reservations:
          memory: 256M

  temple-backend:
    build:
      context: ../backend
      dockerfile: ../backend/Dockerfile
    container_name: temple-backend
    environment:
      DATABASE_URL: postgresql://${POSTGRES_USER:-postgres}:${POSTGRES_PASSWORD:-postgres}@temple-db:5432/${POSTGRES_DB:-temple_os}
      JWT_SECRET: ${JWT_SECRET:-temple-jwt-secret-change-in-production}
      PORT: 3002
      NODE_ENV: production
    volumes:
      - ./logs:/app/logs
    networks:
      - temple-network
    depends_on:
      temple-db:
        condition: service_healthy
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:3002/api/health || exit 1"]
      interval: 15s
      timeout: 5s
      retries: 3
      start_period: 30s
    deploy:
      resources:
        limits:
          memory: 512M
        reservations:
          memory: 256M

  temple-frontend:
    build:
      context: ../frontend
      dockerfile: ../frontend/Dockerfile
      args:
        NEXT_PUBLIC_API_BASE: ${NEXT_PUBLIC_API_BASE:-}
    container_name: temple-frontend
    environment:
      NEXT_PUBLIC_API_BASE: ${NEXT_PUBLIC_API_BASE:-}
      NODE_ENV: production
    networks:
      - temple-network
    depends_on:
      temple-backend:
        condition: service_healthy
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:3000 || exit 1"]
      interval: 15s
      timeout: 5s
      retries: 3
      start_period: 30s
    deploy:
      resources:
        limits:
          memory: 512M
        reservations:
          memory: 256M

  temple-print:
    build:
      context: ../print-service
      dockerfile: ../print-service/Dockerfile
    container_name: temple-print
    environment:
      PORT: 3001
      NODE_ENV: production
    networks:
      - temple-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:3001/health || exit 1"]
      interval: 15s
      timeout: 5s
      retries: 3
      start_period: 10s
    deploy:
      resources:
        limits:
          memory: 256M
        reservations:
          memory: 128M

  temple-nginx:
    image: nginx:alpine
    container_name: temple-nginx
    ports:
      - "${HTTP_PORT:-80}:80"
      - "${HTTPS_PORT:-443}:443"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - ./ssl:/etc/nginx/ssl:ro
      - ./logs:/var/log/nginx
    networks:
      - temple-network
    depends_on:
      temple-frontend:
        condition: service_healthy
      temple-backend:
        condition: service_healthy
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 128M
        reservations:
          memory: 64M

networks:
  temple-network:
    driver: bridge

volumes:
  postgres_data:

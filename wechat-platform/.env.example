# Temple OS central WeChat platform environment template
# Copy to wechat-platform/.env on the center platform server.

# Runtime
NODE_ENV=development
PORT=3010
PUBLIC_BASE_URL=https://wechat-platform.example.com

# WeChat Open Platform third-party platform settings.
# These values come from the official WeChat Open Platform console.
WECHAT_COMPONENT_APP_ID=wx_component_app_id
WECHAT_COMPONENT_SECRET=change-this-component-secret
WECHAT_COMPONENT_TOKEN=change-this-component-token
WECHAT_COMPONENT_ENCODING_AES_KEY=change-this-encoding-aes-key

# API token used by customer Temple OS servers when calling this center service.
# Use a long random value and keep it identical to customer server WECHAT_PLATFORM_API_TOKEN.
WECHAT_PLATFORM_API_TOKEN=change-this-shared-platform-api-token

# Keep true until real official-account authorization and templates have been verified.
# Set to false only when the center platform should send real WeChat messages/publish requests.
WECHAT_PLATFORM_DRY_RUN=true

# Development persistence. This directory contains tokens and must not be committed.
WECHAT_PLATFORM_DATA_DIR=./data

# Production persistence. Early validation uses WECHAT_PLATFORM_DATA_DIR; production should enable a database.
DATABASE_URL=postgresql://postgres:change-this-password@localhost:5432/temple_wechat_platform
